# Inputs for deploy/railway-bootstrap.sh.
# Copy to deploy/.env.railway (gitignored) and fill in. Required values must be
# non-empty; optional ones can stay blank.

# ---- Optional: Railway project name ----
# Used only when no project is linked yet. Defaults to "origin-squid-<branch>".
# RAILWAY_PROJECT_NAME=origin-squid-prod

# ---- Required: chain RPC endpoints ----
# Anything compatible with the existing dev.env values. URL must include any
# auth bits the provider expects (path-based key, query string, etc.).
RPC_ENDPOINT=
RPC_BASE_ENDPOINT=
RPC_ARBITRUM_ENDPOINT=
RPC_SONIC_ENDPOINT=
RPC_HYPEREVM_ENDPOINT=

# ---- Optional: integrations ----
# Leave blank to disable; processors that read these will skip the integration.
NOTION_SECRET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
